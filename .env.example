# Hugging Face token. Optional for pixallm SFT v1 (m1guelpf/nouns is CC0/public),
# required later if you pull gated models or push checkpoints to the Hub.
HF_TOKEN=

# Weights & Biases API key. Required only when running training with
# `--report-to wandb`. Get yours from https://wandb.ai/authorize
WANDB_API_KEY=
